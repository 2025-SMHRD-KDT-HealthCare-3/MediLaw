# ===== fastapi(AI 서버) 환경변수 예시 =====
# 이 파일을 복사해 .env 로 만들고 실제 값을 채우세요 (.env 는 커밋되지 않음).
#   cp .env.example .env

# OpenAI 키 — 임베딩 생성 + LLM 답변 생성에 사용
OPENAI_API_KEY=

# ----- 아래는 기본값이라 그대로 둬도 됩니다 -----
DB_PATH=data/medilaw.db

# 비우면 인증 끔(로컬). 공개 배포 시에만 채움
API_KEYS=

# 분당 호출 한도 (IP/키별)
RATE_LIMIT_PER_MIN=30

# 생성 LLM 추론 강도(gpt-5계열) — low면 완답 약 절반(권장). 빈값=모델 기본. low|medium|high
REASONING_EFFORT=low

# 법제처 국가법령정보 공동활용 OC 키 — 법령 개정 현황 대시보드(/v1/laws/*)용.
# 호출 IP/도메인 등록 필요(미등록 시 HTML 에러). 발급: https://open.law.go.kr
LAW_OC=H-Lab

# PDF 스캔본 OCR 백엔드. 기본 paddleocr_vl(자체호스팅, 데이터 국내처리).
# 모델 가중치를 못 받는 환경에선 OCR이 빈 결과 → 개발/클라우드는 vision(gpt-5.5).
OCR_BACKEND=paddleocr_vl
# PADDLE_OCR_VL_SERVER_URL=   # (선택) 자체호스팅 vLLM 서버 URL
