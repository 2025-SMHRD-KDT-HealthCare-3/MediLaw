# 사용법: 이 파일을 복사해 .env 로 만들고 값을 채우세요.
#   (윈도우)  copy .env.example .env
#   (mac/리눅스)  cp .env.example .env
# .env 는 git에 올라가지 않습니다(비밀번호 보호).

# 팀 공용 원격 MySQL 접속 URL. 팀에서 공유받은 사용자/비밀번호/DB이름으로 채우세요.
DATABASE_URL=mysql+pymysql://<USER>:<PASSWORD>@project-db-campus.smhrd.com:3312/<DBNAME>

# (선택) 로그인 토큰 서명키
# JWT_SECRET_KEY=change-me-please
